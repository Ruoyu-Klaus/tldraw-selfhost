# 复制此文件为 .env.local 并填入你的 license key
# 申请地址：
#   Hobby（非商业免费）: https://tldraw.dev/get-a-license/hobby
#   Trial（100天试用）: https://tldraw.dev/get-a-license/trial
VITE_TLDRAW_LICENSE_KEY=tldraw-xxxxxxxxxxxxxxxx

# ── MCP Server 鉴权 ────────────────────────────────────────────────────────────
# 生成随机 Token：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 仅服务端（Fastify）和 MCP Server 进程使用，不会暴露到浏览器
MCP_TOKEN=change-me-to-a-random-secret

# MCP Server 连接的 tldraw 服务地址
# 本地开发：http://localhost:5858
# 外网生产：https://your-domain.com（CF Tunnel 地址）
TLDRAW_BASE_URL=http://localhost:5858

# ── Cloudflare Zero Trust Service Token（外网访问 MCP 时需要）────────────────
# 在 CF Zero Trust → Access → Service Auth 里创建 Service Token
# 浏览器端不需要，浏览器用自己的 Zero Trust session
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
